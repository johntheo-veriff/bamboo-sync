rules_version = '2';

// All Firestore access goes through the Firebase Admin SDK (Next.js API routes
// and Cloud Functions). The Admin SDK bypasses these rules entirely.
// Denying all client-side access is intentional — no direct browser → Firestore
// reads or writes are used in this application.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}