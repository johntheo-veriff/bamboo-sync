{
  "compilerOptions": {
    "module": "commonjs",
    "esModuleInterop": true,
    "moduleResolution": "node10",
    "ignoreDeprecations": "6.0",
    "noImplicitReturns": true,
    "noUnusedLocals": false,
    "sourceMap": true,
    "strict": true,
    "target": "es2017",
    "noEmit": true,
    "paths": {
      "@/*": ["../src/*"]
    }
  },
  "compileOnSave": true,
  "include": [
    "src",
    "../src"
  ],
  "exclude": [
    "../src/app",
    "../src/**/*.test.ts",
    "../node_modules"
  ]
}
